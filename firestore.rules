
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظيفة للتحقق مما إذا كان المستخدم مديراً معتمداً
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email in ["atlob.co@gmail.com", "alaujantravel@gmail.com"] || 
        request.auth.token.email.matches(".*@alawajan\\.com")
      );
    }

    // وظيفة للتحقق من ملكية البيانات
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ملفات المستخدمين
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /bookings/{bookingId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // قواعد خاصة باستعلامات المجموعات (Collection Groups)
    // ضرورية جداً لكشف الركاب وتتبع الطرود الشامل
    match /{path=**}/bookings/{id} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }
    
    match /{path=**}/parcels/{id} {
      allow read, write: if isAdmin() || (request.auth != null && resource.data.senderUserId == request.auth.uid);
    }

    // البيانات العامة
    match /locations/{id} { allow read: if true; allow write: if isAdmin(); }
    match /buses/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /busRoutes/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /busTrips/{id} { allow read: if true; allow write: if isAdmin(); }
    match /drivers/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /staff_permissions/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    
    // خدمة البريد
    match /mail/{id} { allow create: if true; }
  }
}
