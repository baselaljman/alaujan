rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * قاعدة شاملة (Universal Rule): أي مستخدم مسجل دخول يمكنه القراءة والكتابة في أي مكان.
     * هذا يضمن تجاوز كافة مشاكل الصلاحيات في لوحة الإدارة وقسم الحجوزات.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    /**
     * تصريحات صريحة ومباشرة لاستعلامات المجموعات (Collection Group Queries).
     * ضرورية جداً للسماح بالبحث في المجموعات المتداخلة (مثل الحجوزات والطرود) عبر كامل قاعدة البيانات.
     */
    match /{path=**}/bookings/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /{path=**}/parcels/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /{path=**}/staff_permissions/{id} {
      allow read, write: if request.auth != null;
    }

    match /{path=**}/busTrips/{id} {
      allow read, write: if request.auth != null;
    }

    /**
     * بصمة التحديث القسري لضمان النشر الفوري وتجاوز التخزين المؤقت:
     * DEPLOY_HASH: FINAL-STABILITY-V200
     */
  }
}