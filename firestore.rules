
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظائف التحقق الأساسية
    function isAuthenticated() {
      return request.auth != null;
    }

    function getEmail() {
      return request.auth.token.email.lower();
    }

    function hasEmail() {
      return isAuthenticated() && 'email' in request.auth.token && request.auth.token.email != null;
    }

    // التحقق من صلاحيات المدير العام
    function isAdmin() {
      return hasEmail() && (
        getEmail() in ["atlob.co@gmail.com", "alaujantravel@gmail.com"] || 
        getEmail().matches(".*@alawajan\\.com")
      );
    }

    // التحقق من صلاحيات الموظف
    function isStaffMember() {
      return hasEmail() && exists(/databases/$(database)/documents/staff_permissions/$(getEmail()));
    }

    // 1. الرحلات والبيانات العامة: قراءة للجميع، تحديث المقاعد للمسافرين، تحكم كامل للمدير
    match /busTrips/{id} { 
      allow read: if true; 
      allow update: if isAuthenticated() && (
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['availableSeats', 'updatedAt'])) ||
        isAdmin() || isStaffMember()
      );
      allow create, delete: if isAdmin() || isStaffMember();
    }
    
    match /locations/{id} { allow read: if true; allow write: if isAdmin() || isStaffMember(); }
    match /buses/{id} { allow read: if true; allow write: if isAdmin() || isStaffMember(); }
    match /drivers/{id} { allow read: if true; allow write: if isAdmin() || isStaffMember(); }
    match /staff_permissions/{email} { allow read: if true; allow write: if isAdmin(); }

    // 2. نظام الحجوزات: خصوصية تامة
    match /bookings/{bookingId} {
      allow create: if true;
      // السماح بالقراءة فقط إذا كان مديراً أو صاحب التذكرة (بالبريد أو الـ UID)
      allow read: if isAdmin() || isStaffMember() || (
        isAuthenticated() && (
          resource.data.userId == request.auth.uid || 
          (hasEmail() && resource.data.userEmail == getEmail())
        )
      );
      allow update, delete: if isAdmin() || isStaffMember();
    }

    // 3. الطرود والشحنات
    match /parcels/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin() || isStaffMember() || isAuthenticated();
    }

    // 4. ملفات المستخدمين
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId || isAdmin();
    }

    // القاعدة العامة للأمان
    match /{path=**} {
      allow read: if isAdmin() || isStaffMember();
      allow write: if isAdmin();
    }
  }
}
