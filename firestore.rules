
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظائف التحقق الأساسية
    function isAuthenticated() {
      return request.auth != null;
    }

    function getEmail() {
      return request.auth.token.email;
    }

    function hasEmail() {
      return isAuthenticated() && 'email' in request.auth.token && getEmail() != null;
    }

    function isAdmin() {
      return hasEmail() && (
        getEmail() in ["atlob.co@gmail.com", "alaujantravel@gmail.com"] || 
        getEmail().matches(".*@alawajan\\.com")
      );
    }

    function isStaffMember() {
      return hasEmail() && exists(/databases/$(database)/documents/staff_permissions/$(getEmail()));
    }

    function hasStaffPermission(permission) {
      return isStaffMember() && get(/databases/$(database)/documents/staff_permissions/$(getEmail())).data.permissions[permission] == true;
    }

    // نظام الحجوزات - تأمين صارم للخصوصية ومنع تسريب البيانات
    match /bookings/{bookingId} {
      allow create: if true; // السماح للجميع ببدء عملية حجز (كضيف أو مسجل)
      
      // السماح بالـ list فقط إذا كان الاستعلام "مفلتراً" بدقة
      allow list: if isAdmin() || hasStaffPermission('canManageTrips') || (
        // 1. السماح للجميع برؤية المقاعد المحجوزة فقط (لغرض اختيار المقاعد)
        (request.query.filters.busTripId != null) ||
        // 2. السماح للمسجلين برؤية تذاكرهم المرتبطة ببريدهم الموثق
        (hasEmail() && request.query.filters.userEmail == getEmail()) ||
        // 3. السماح للضيوف برؤية تذاكرهم المرتبطة برقم جلستهم الحالية (UID)
        (isAuthenticated() && request.query.filters.userId == request.auth.uid)
      );
      
      // السماح بـ get (التفاصيل الكاملة) فقط للمالك أو الإدارة
      allow get: if isAdmin() || 
                  hasStaffPermission('canManageTrips') || 
                  (isAuthenticated() && (
                    resource.data.userId == request.auth.uid || 
                    (hasEmail() && resource.data.userEmail == getEmail())
                  ));
      
      allow update: if isAdmin() || hasStaffPermission('canManageTrips');
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if true;
    }

    match /locations/{id} { allow read: if true; }
    
    match /busTrips/{id} { 
      allow read: if true;
      // السماح للمستخدمين بتحديث عدد المقاعد المتاحة عند الحجز
      allow update: if isAuthenticated(); 
    }
    
    match /buses/{id} { allow read: if true; }
    
    match /parcels/{id} {
      allow read: if isAdmin() || 
                   hasStaffPermission('canManageParcels') || 
                   (hasEmail() && resource.data.recipientEmail == getEmail()) ||
                   (hasEmail() && resource.data.senderEmail == getEmail());
      allow create: if isAuthenticated();
      allow update: if isAdmin() || hasStaffPermission('canManageParcels');
    }
    
    match /staff_permissions/{email} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /drivers/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // القاعدة العامة للمديرين فقط
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
