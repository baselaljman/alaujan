
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظيفة مساعدة للتحقق من هوية المدير العام
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email in ["atlob.co@gmail.com", "alaujantravel@gmail.com"] || 
        request.auth.token.email.matches(".*@alawajan\\.com")
      );
    }

    // قواعد ملفات المستخدمين: الخصوصية التامة
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      match /bookings/{bookingId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
      
      match /notifications/{notificationId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }
    
    // السماح بقراءة صلاحيات الموظفين (للتحقق عند الدخول)
    match /staff_permissions/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // السماح باستعلامات المجموعات (Collection Group Queries) للحجوزات والطرود
    match /{path=**}/bookings/{id} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }
    
    match /{path=**}/parcels/{id} {
      allow read, write: if request.auth != null && (resource == null || resource.data.senderUserId == request.auth.uid || isAdmin());
    }

    // البيانات العامة (رحلات، مدن، حافلات)
    match /locations/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /buses/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /busRoutes/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /busTrips/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    
    // خدمة إرسال الإيميلات
    match /mail/{id} { allow create: if request.auth != null; }

    /**
     * تحديث أمان شامل: تصحيح صلاحيات الموظفين والمدراء
     * DEPLOY_HASH: SECURE-FINAL-V900
     */
  }
}
