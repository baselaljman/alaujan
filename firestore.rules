rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * 1. القاعدة العالمية (Recursive Match)
     * تسمح بالقراءة والكتابة لكافة المستندات في المسارات العادية.
     */
    match /{document=**} {
      allow read, write: if true;
    }
    
    /**
     * 2. قواعد استعلامات المجموعات (Collection Group Rules)
     * ضرورية جداً لعمليات البحث التي تتم عبر collectionGroup() مثل الحجوزات والطرود.
     * نستخدم {path=**} للسماح بالاستعلام عن المجموعات أياً كان عمقها في قاعدة البيانات.
     */
    
    match /{path=**}/bookings/{bookingId} {
      allow read, write: if true;
    }
    
    match /{path=**}/parcels/{parcelId} {
      allow read, write: if true;
    }
    
    match /{path=**}/busTrips/{tripId} {
      allow read, write: if true;
    }

    match /{path=**}/users/{userId} {
      allow read, write: if true;
    }

    match /{path=**}/locations/{locationId} {
      allow read, write: if true;
    }

    match /{path=**}/staff_permissions/{staffId} {
      allow read, write: if true;
    }

    /**
     * تحديث لضمان إعادة نشر القواعد فوراً.
     * Timestamp: 2024-05-21T12:00:00Z
     */
  }
}