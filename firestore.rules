rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // السماح بالقراءة والكتابة العامة لجميع الجداول بدون قيود تقنية بناءً على طلب العميل
    match /{document=**} {
      allow read, write: if true;
    }

    // القواعد المخصصة لضمان السرعة والوضوح
    match /busTrips/{id} { allow read, write: if true; }
    match /locations/{id} { allow read, write: if true; }
    match /buses/{id} { allow read, write: if true; }
    match /drivers/{id} { allow read, write: if true; }
    match /bookings/{id} { allow read, write: if true; }
    match /parcels/{id} { allow read, write: if true; }
    match /users/{id} { allow read, write: if true; }
    match /staff_permissions/{id} { allow read, write: if true; }
  }
}