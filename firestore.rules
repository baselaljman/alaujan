
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // القاعدة العامة: السماح بالقراءة والكتابة لجميع المستندات
    match /{document=**} {
      allow read, write: if true;
    }

    // قاعدة خاصة للاستعلامات المجمعة (Collection Group Queries)
    // هذا ضروري لعمل "بيان الركاب" في لوحة الإدارة
    match /bookings/{bookingId} {
      allow read, write: if true;
    }
    
    match /parcels/{parcelId} {
      allow read, write: if true;
    }
  }
}
