
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * APP SECURITY STRATEGY: Al-Awajan Travel
     * تم فتح الصلاحيات بالكامل وتحديد المجموعات لضمان عمل الاستعلامات المجمعة
     */

    // السماح بالقراءة والكتابة لجميع المسارات
    match /{document=**} {
      allow read, write: if true;
    }

    // تصريح خاص للمجموعات المجمعة (Collection Group) لضمان عدم حدوث خطأ Permission Denied
    match /{path=**}/bookings/{bookingId} {
      allow read, write: if true;
    }
    
    match /{path=**}/parcels/{parcelId} {
      allow read, write: if true;
    }

    match /{path=**}/busTrips/{tripId} {
      allow read, write: if true;
    }
  }
}
