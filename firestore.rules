rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * قاعدة ذهبية: أي مستخدم مسجل دخول (سواء بريد أو مجهول) يمكنه القراءة والكتابة.
     * هذا يحل مشكلة الصلاحيات بشكل قطعي ويسمح للوحة الإدارة بالعمل فوراً.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    /**
     * تصريحات صريحة لاستعلامات المجموعات (Collection Group Queries).
     * ضرورية جداً لجلب الحجوزات والطرود عبر كامل قاعدة البيانات.
     */
    match /{path=**}/bookings/{bookingId} {
      allow read, write: if request.auth != null;
    }
    
    match /{path=**}/parcels/{parcelId} {
      allow read, write: if request.auth != null;
    }
    
    match /{path=**}/staff_permissions/{staffId} {
      allow read, write: if request.auth != null;
    }

    /**
     * بصمة التحديث الإجباري لضمان النشر الفوري: FORCE-RESET-V100
     */
  }
}