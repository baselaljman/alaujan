
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظائف التحقق الأساسية
    function isAuthenticated() {
      return request.auth != null;
    }

    function getEmail() {
      return request.auth.token.email;
    }

    function hasEmail() {
      return isAuthenticated() && 'email' in request.auth.token && getEmail() != null;
    }

    function isAdmin() {
      return hasEmail() && (
        getEmail() in ["atlob.co@gmail.com", "alaujantravel@gmail.com"] || 
        getEmail().matches(".*@alawajan\\.com")
      );
    }

    function isStaffMember() {
      return hasEmail() && exists(/databases/$(database)/documents/staff_permissions/$(getEmail()));
    }

    function hasStaffPermission(permission) {
      return isStaffMember() && get(/databases/$(database)/documents/staff_permissions/$(getEmail())).data.permissions[permission] == true;
    }

    // نظام الحجوزات - ربط مزدوج (UID للجلسة والبريد للهوية الدائمة)
    match /bookings/{bookingId} {
      allow create: if isAuthenticated();
      
      // السماح بـ list في الحالات التالية:
      // 1. المسؤولين والموظفين (قراءة الكل)
      // 2. صاحب الجلسة الحالية (UID) - يتيح للضيوف رؤية تذاكرهم فورياً
      // 3. صاحب البريد الإلكتروني الموثق - يتيح للمسجلين استعادة تاريخهم
      allow list: if isAdmin() || 
                   hasStaffPermission('canManageTrips') || 
                   (isAuthenticated() && resource.data.userId == request.auth.uid) ||
                   (hasEmail() && resource.data.userEmail == getEmail());
      
      allow get: if isAdmin() || 
                  hasStaffPermission('canManageTrips') || 
                  (isAuthenticated() && resource.data.userId == request.auth.uid) ||
                  (hasEmail() && resource.data.userEmail == getEmail());
      
      allow update: if isAdmin() || hasStaffPermission('canManageTrips');
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated();
    }

    match /locations/{id} { allow read: if true; }
    
    match /busTrips/{id} { 
      allow read: if true;
      // السماح بتحديث عدد المقاعد لكافة المسجلين لضمان نجاح عملية الخصم أثناء الحجز
      allow update: if isAuthenticated();
    }
    
    match /buses/{id} { allow read: if true; }
    
    match /parcels/{id} {
      allow read: if isAdmin() || 
                   hasStaffPermission('canManageParcels') || 
                   (hasEmail() && resource.data.recipientEmail == getEmail()) ||
                   (hasEmail() && resource.data.senderEmail == getEmail());
      allow create: if isAuthenticated();
      allow update: if isAdmin() || hasStaffPermission('canManageParcels');
    }
    
    match /staff_permissions/{email} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /drivers/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
