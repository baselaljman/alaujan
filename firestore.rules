
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && 
             'email' in request.auth.token && 
             (
               request.auth.token.email in ["atlob.co@gmail.com", "alaujantravel@gmail.com"] || 
               request.auth.token.email.matches(".*@alawajan\\.com")
             );
    }

    function hasStaffPermission(permission) {
      return request.auth != null && 
             'email' in request.auth.token &&
             exists(/databases/$(database)/documents/staff_permissions/$(request.auth.token.email)) &&
             get(/databases/$(database)/documents/staff_permissions/$(request.auth.token.email)).data.permissions[permission] == true;
    }

    match /{path=**} {
      allow read, write: if isAdmin();
    }

    // نظام الحجوزات الموحد
    match /bookings/{bookingId} {
      // السماح للمديرين والموظفين المخولين بقراءة كافة الحجوزات
      // السماح للمستخدمين بقراءة حجوزاتهم الخاصة فقط
      allow read: if isAdmin() || 
                   hasStaffPermission('canManageTrips') || 
                   (request.auth != null && resource.data.userId == request.auth.uid);
      
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    match /locations/{id} { allow read: if true; }
    match /busTrips/{id} { allow read: if true; }
    match /buses/{id} { allow read: if true; }
    match /busRoutes/{id} { allow read: if true; }
    
    match /parcels/{id} {
      allow read: if request.auth != null && (
        isAdmin() || 
        hasStaffPermission('canManageParcels') || 
        resource.data.senderUserId == request.auth.uid ||
        resource.data.userId == request.auth.uid
      );
      allow create: if request.auth != null;
      allow update: if isAdmin() || hasStaffPermission('canManageParcels');
    }
    
    match /reviews/{id} {
      allow read: if true;
      allow create: if request.auth != null;
    }

    match /staff_permissions/{email} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /drivers/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
