rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * APP SECURITY STRATEGY: Al-Awajan Travel (Prototyping Phase)
     * 
     * NOTE: For the current prototyping phase, rules have been set to 'true' 
     * for all paths to allow the user to build the database and manage 
     * trips/parcels/locations without authentication hurdles.
     * In production, these should be restricted to authenticated owners/admins.
     */

    // Permissive rule for all documents and collection groups
    match /{document=**} {
      allow read, write: if true;
    }

    // Explicitly allow collection group queries for bookings (used in Admin Manifest)
    match /{path=**}/bookings/{bookingId} {
      allow read, write: if true;
    }
  }
}