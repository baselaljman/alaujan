
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getEmail() {
      return isAuthenticated() && 'email' in request.auth.token ? request.auth.token.email.lower() : null;
    }

    function hasEmail() {
      return isAuthenticated() && 'email' in request.auth.token && request.auth.token.email != null;
    }

    function isAdmin() {
      return hasEmail() && (
        getEmail() in ["atlob.co@gmail.com", "alaujantravel@gmail.com"]
      );
    }

    function isStaffMember() {
      return hasEmail() && exists(/databases/$(database)/documents/staff_permissions/$(getEmail()));
    }

    function isDriver() {
      return hasEmail() && exists(/databases/$(database)/documents/drivers/$(getEmail()));
    }

    // الرحلات: قراءة عامة للجميع لتمكين الحجز
    match /busTrips/{id} { 
      allow read: if true; 
      // السماح بتحديث المقاعد المتاحة والموقع المباشر
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['availableSeats', 'updatedAt', 'currentLat', 'currentLng', 'lastLocationUpdate', 'isLive', 'status', 'currentLocationDescription']);
      allow create, delete: if isAdmin() || isStaffMember();
    }
    
    match /locations/{id} { allow read: if true; allow write: if isAdmin() || isStaffMember(); }
    match /buses/{id} { allow read: if true; allow write: if isAdmin() || isStaffMember(); }
    match /drivers/{email} { allow read: if true; allow write: if isAdmin() || isStaffMember(); }
    match /staff_permissions/{email} { allow read: if true; allow write: if isAdmin(); }

    // الحجوزات: حماية خصوصية مطلقة
    match /bookings/{bookingId} {
      allow create: if true;
      // السماح بجلب تذكرة محددة لصاحبها أو المسؤول
      allow get: if isAdmin() || isStaffMember() || (
        isAuthenticated() && (
          resource.data.userId == request.auth.uid || 
          (hasEmail() && resource.data.userEmail.lower() == getEmail())
        )
      );
      // السماح بالقوائم المفلترة فقط لضمان عدم تسريب البيانات
      allow list: if isAdmin() || isStaffMember() || (
        isAuthenticated() && (
          (request.query.limit <= 100 && 'userEmail' in request.query.filters && request.query.filters.userEmail.lower() == getEmail()) ||
          (request.query.limit <= 100 && 'userId' in request.query.filters && request.query.filters.userId == request.auth.uid)
        )
      );
      allow update, delete: if isAdmin() || isStaffMember();
    }

    match /parcels/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin() || isStaffMember() || isDriver() || isAuthenticated();
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || isStaffMember());
    }
  }
}
