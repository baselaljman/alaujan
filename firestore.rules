rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * 1. القاعدة العالمية (Recursive Match)
     * تسمح بالقراءة والكتابة لكافة المستندات في المسارات القياسية.
     */
    match /{document=**} {
      allow read, write: if true;
    }
    
    /**
     * 2. قواعد استعلامات المجموعات (Collection Group Rules)
     * ضرورية جداً لعمليات البحث التي تتم عبر collectionGroup() مثل الحجوزات والطرود.
     * نستخدم {path=**} للسماح بالاستعلام عن المجموعات أياً كان عمقها في قاعدة البيانات.
     */
    
    match /{path=**}/bookings/{id} {
      allow read, write: if true;
    }
    
    match /{path=**}/parcels/{id} {
      allow read, write: if true;
    }
    
    match /{path=**}/busTrips/{id} {
      allow read, write: if true;
    }

    match /{path=**}/users/{id} {
      allow read, write: if true;
    }

    match /{path=**}/locations/{id} {
      allow read, write: if true;
    }

    match /{path=**}/staff_permissions/{id} {
      allow read, write: if true;
    }

    /**
     * تحديث إجباري لإعادة نشر القواعد فوراً وضمان تفعيل استعلامات المجموعات.
     * Timestamp: 2025-05-22T14:30:00Z
     */
  }
}