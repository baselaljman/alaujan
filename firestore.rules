rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. السماح بالوصول الكامل لكافة المستندات (لأغراض التطوير الحالية)
    match /{document=**} {
      allow read, write: if true;
    }
    
    // 2. السماح الصريح باستعلامات المجموعات (Collection Group Queries)
    // هذا الجزء ضروري جداً لعمل وظيفة "البحث عن التذاكر عبر البريد" و "إحصائيات المدير"
    // حيث يقوم بالبحث في كافة المجموعات التي تحمل نفس الاسم بغض النظر عن موقعها
    
    match /{path=**}/bookings/{bookingId} {
      allow read, write: if true;
    }
    
    match /{path=**}/parcels/{parcelId} {
      allow read, write: if true;
    }
    
    match /{path=**}/notifications/{notificationId} {
      allow read, write: if true;
    }

    match /{path=**}/staff_permissions/{staffId} {
      allow read, write: if true;
    }
  }
}