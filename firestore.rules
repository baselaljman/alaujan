
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظائف التحقق الأساسية
    function isAuthenticated() {
      return request.auth != null;
    }

    function getEmail() {
      return request.auth.token.email.lower();
    }

    function hasEmail() {
      return isAuthenticated() && 'email' in request.auth.token && request.auth.token.email != null;
    }

    // التحقق من صلاحيات المدير العام
    function isAdmin() {
      return hasEmail() && (
        getEmail() in ["atlob.co@gmail.com", "alaujantravel@gmail.com"] || 
        getEmail().matches(".*@alawajan\\.com")
      );
    }

    // التحقق من صلاحيات الموظف (بناءً على البريد المسجل في مجموعة staff_permissions)
    function isStaffMember() {
      return hasEmail() && exists(/databases/$(database)/documents/staff_permissions/$(getEmail()));
    }

    // التحقق مما إذا كان المستخدم هو صاحب البيانات (عبر البريد أو UID)
    function isOwner(data) {
      return (isAuthenticated() && data.userId == request.auth.uid) || 
             (hasEmail() && data.userEmail.lower() == getEmail());
    }

    // 1. الرحلات الدولية: قراءة عامة للجميع، تحديث المقاعد متاح للكل عند الحجز
    match /busTrips/{id} { 
      allow read: if true;
      allow update: if isAuthenticated(); // للسماح بخصم المقاعد وتحديث موقع السائق
      allow create, delete: if isAdmin() || isStaffMember();
    }
    
    // 2. المواقع، الحافلات، السائقين: قراءة عامة، تعديل للمديرين والموظفين
    match /locations/{id} { allow read: if true; allow write: if isAdmin() || isStaffMember(); }
    match /buses/{id} { allow read: if true; allow write: if isAdmin() || isStaffMember(); }
    match /drivers/{id} { allow read: if true; allow write: if isAdmin() || isStaffMember(); }

    // 3. نظام الحجوزات: يسمح للجميع بطلب "قائمة" لفحص المقاعد المشغولة، ورؤية تذاكرهم فقط
    match /bookings/{bookingId} {
      allow create: if true; // السماح بالحجز كضيف
      
      allow list: if isAdmin() || isStaffMember() || (
        // السماح للكل برؤية المقاعد المشغولة لرحلة معينة (لاختيار المقاعد)
        (request.query.filters.busTripId != null) ||
        // السماح للمالك برؤية تذاكره عبر UID الجلسة أو البريد
        (isAuthenticated() && request.query.filters.userId == request.auth.uid) ||
        (hasEmail() && request.query.filters.userEmail == getEmail())
      );
      
      allow get: if isAdmin() || isStaffMember() || isOwner(resource.data);
      allow update, delete: if isAdmin() || isStaffMember();
    }

    // 4. الطرود والشحنات
    match /parcels/{id} {
      allow read: if isAdmin() || isStaffMember() || 
                   (hasEmail() && (resource.data.recipientEmail == getEmail() || resource.data.senderEmail == getEmail())) ||
                   (isAuthenticated() && resource.data.busTripId != null); // للتتبع عبر رقم الرحلة
      allow create: if isAuthenticated();
      allow update: if isAdmin() || isStaffMember();
    }

    // 5. ملفات المستخدمين
    match /users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }
    
    // 6. صلاحيات الموظفين
    match /staff_permissions/{email} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // القاعدة العامة: المدير العام يملك كافة الصلاحيات على كل شيء
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
