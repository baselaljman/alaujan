rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * 1. القواعد العامة (Global Rules)
     * تسمح بالقراءة والكتابة لأي مستخدم مسجل دخول (Authenticated User).
     * هذه القاعدة تغطي معظم العمليات المباشرة.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    /**
     * 2. تصاريح استعلامات المجموعات (Collection Group Rules)
     * ضرورية جداً للبحث في الحجوزات والطرود والرحلات عبر كامل قاعدة البيانات.
     * Firebase يتطلب هذا التنسيق {path=**}/collectionID/{docID} بشكل صريح للاستعلامات المجمعة.
     */
    
    // تصريح للحجوزات (المستخدم في لوحة الإدارة والبروفايل)
    match /{path=**}/bookings/{id} {
      allow read, write: if request.auth != null;
    }
    
    // تصريح للطرود
    match /{path=**}/parcels/{id} {
      allow read, write: if request.auth != null;
    }
    
    // تصريح للرحلات
    match /{path=**}/busTrips/{id} {
      allow read, write: if request.auth != null;
    }

    // تصريح لبيانات المستخدمين
    match /{path=**}/users/{id} {
      allow read, write: if request.auth != null;
    }

    // تصريح للمواقع والمدن
    match /{path=**}/locations/{id} {
      allow read, write: if request.auth != null;
    }

    // تصريح للحافلات والأسطول
    match /{path=**}/buses/{id} {
      allow read, write: if request.auth != null;
    }

    // تصريح لنظام البريد الإلكتروني
    match /{path=**}/mail/{id} {
      allow read, write: if request.auth != null;
    }

    /**
     * إجبار النظام على تحديث القواعد فوراً لضمان حل مشكلة "Missing or insufficient permissions".
     * Force Deploy Timestamp: 2025-05-23T14:30:00Z
     */
  }
}