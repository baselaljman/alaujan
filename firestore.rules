
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // السماح الكامل لجميع العمليات على كافة المسارات والمجموعات
    // هذا يحل مشكلة الاستعلامات المجمعة (Collection Group) وصلاحيات الحذف
    match /{document=**} {
      allow read, write: if true;
    }
    
    // تصريح إضافي صريح للمجموعات التي قد تُطلب بشكل مجمع
    match /bookings/{bookingId} {
      allow read, write: if true;
    }
  }
}
