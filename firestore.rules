
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظائف التحقق الأساسية
    function isAuthenticated() {
      return request.auth != null;
    }

    function getEmail() {
      return request.auth.token.email;
    }

    function hasEmail() {
      return isAuthenticated() && 'email' in request.auth.token && getEmail() != null;
    }

    // التحقق من الهوية الإدارية (بناءً على البريد الإلكتروني حصراً)
    function isAdmin() {
      return hasEmail() && (
        getEmail() in ["atlob.co@gmail.com", "alaujantravel@gmail.com"] || 
        getEmail().matches(".*@alawajan\\.com")
      );
    }

    function isStaffMember() {
      return hasEmail() && exists(/databases/$(database)/documents/staff_permissions/$(getEmail()));
    }

    function hasStaffPermission(permission) {
      return isStaffMember() && get(/databases/$(database)/documents/staff_permissions/$(getEmail())).data.permissions[permission] == true;
    }

    // نظام الحجوزات الموحد - الاعتماد الكلي على البريد الإلكتروني لفك الارتباط بالـ UID
    match /bookings/{bookingId} {
      allow create: if isAuthenticated();
      
      // السماح بالقراءة فقط للمسؤولين أو صاحب الحجز بناءً على البريد الإلكتروني الموثق في التوكن
      allow list: if isAdmin() || hasStaffPermission('canManageTrips') || (hasEmail() && resource.data.userEmail == getEmail());
      allow get: if isAdmin() || hasStaffPermission('canManageTrips') || (hasEmail() && resource.data.userEmail == getEmail());
      
      allow update: if isAdmin() || hasStaffPermission('canManageTrips');
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated();
    }

    match /locations/{id} { allow read: if true; }
    
    match /busTrips/{id} { 
      allow read: if true;
      // السماح بتحديث عدد المقاعد أثناء الحجز لكافة المسجلين (حتى الضيوف)
      allow update: if isAuthenticated();
    }
    
    match /buses/{id} { allow read: if true; }
    
    match /parcels/{id} {
      allow read: if isAdmin() || 
                   hasStaffPermission('canManageParcels') || 
                   (hasEmail() && resource.data.recipientEmail == getEmail()) ||
                   (hasEmail() && resource.data.senderEmail == getEmail());
      allow create: if isAuthenticated();
      allow update: if isAdmin() || hasStaffPermission('canManageParcels');
    }
    
    match /staff_permissions/{email} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /drivers/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // صلاحيات المدير العام على كافة الوثائق
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
