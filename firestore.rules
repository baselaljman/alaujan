
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظائف التحقق الأساسية
    function isAuthenticated() {
      return request.auth != null;
    }

    function getEmail() {
      return request.auth.token.email.lower();
    }

    function hasEmail() {
      return isAuthenticated() && 'email' in request.auth.token && request.auth.token.email != null;
    }

    // التحقق من صلاحيات المدير العام
    function isAdmin() {
      return hasEmail() && (
        getEmail() in ["atlob.co@gmail.com", "alaujantravel@gmail.com"] || 
        getEmail().matches(".*@alawajan\\.com")
      );
    }

    // التحقق من صلاحيات الموظف (بناءً على البريد المسجل في مجموعة staff_permissions)
    function isStaffMember() {
      return hasEmail() && exists(/databases/$(database)/documents/staff_permissions/$(getEmail()));
    }

    // 1. البيانات العامة: قراءة متاحة للجميع (أجهزة جديدة)
    match /busTrips/{id} { allow read: if true; allow write: if isAuthenticated(); }
    match /locations/{id} { allow read: if true; allow write: if isAdmin() || isStaffMember(); }
    match /buses/{id} { allow read: if true; allow write: if isAdmin() || isStaffMember(); }
    match /drivers/{id} { allow read: if true; allow write: if isAdmin() || isStaffMember(); }
    match /staff_permissions/{email} { allow read: if true; allow write: if isAdmin(); }

    // 2. نظام الحجوزات: سماح بالقراءة العامة لضمان استقرار العرض، مع حماية الحذف والتعديل
    match /bookings/{bookingId} {
      allow create: if true;
      allow read: if true; // السماح بالقراءة لضمان ظهور التذاكر واستقرار الجلسات
      allow update, delete: if isAdmin() || isStaffMember();
    }

    // 3. الطرود والشحنات: تتبع متاح للجميع برقم الشحنة
    match /parcels/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin() || isStaffMember() || isAuthenticated();
    }

    // 4. ملفات المستخدمين
    match /users/{userId} {
      allow read, write: if true;
    }

    // القاعدة العامة للأمان
    match /{path=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
