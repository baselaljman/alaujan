rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * 1. القواعد العامة (Global Rules)
     * تسمح بالقراءة والكتابة لأي مستخدم مسجل دخول (Authenticated User).
     * النمط {document=**} يغطي كافة المستندات في كافة المجموعات.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    /**
     * 2. تصاريح استعلامات المجموعات (Collection Group Rules) - هامة جداً
     * يجب التصريح عنها صراحة باستخدام النمط {path=**} للسماح بالاستعلام عبر كامل قاعدة البيانات.
     */
    
    // تصريح لمجموعة الحجوزات (تستخدم في الإدارة والبروفايل)
    match /{path=**}/bookings/{bookingId} {
      allow read, write: if request.auth != null;
    }
    
    // تصريح لمجموعة الطرود (تستخدم في التتبع والبحث)
    match /{path=**}/parcels/{parcelId} {
      allow read, write: if request.auth != null;
    }
    
    // تصريح لمجموعة الرحلات
    match /{path=**}/busTrips/{tripId} {
      allow read, write: if request.auth != null;
    }

    // تصريح لبيانات المستخدمين والموظفين
    match /{path=**}/users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /{path=**}/staff_permissions/{staffId} {
      allow read, write: if request.auth != null;
    }

    /**
     * إجبار النظام على تحديث القواعد فوراً لضمان حل مشكلة "Missing or insufficient permissions".
     * تم تحديث القواعد لتكون شاملة وصريحة لكافة أنواع الاستعلامات.
     * Force Deploy Timestamp: 2025-05-23T18:30:00Z
     */
  }
}