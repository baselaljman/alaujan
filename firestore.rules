rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * APP SECURITY STRATEGY: Al-Awajan Travel (Prototyping Phase)
     * 
     * تم فتح الصلاحيات بشكل كامل لضمان عمل كافة ميزات لوحة التحكم 
     * والاستعلامات المجمعة (Collection Group Queries) بدون عوائق.
     */

    // السماح بالقراءة والكتابة لكافة المستندات والمجموعات
    match /{document=**} {
      allow read, write: if true;
    }

    // تأكيد إضافي للسماح بالاستعلامات المجمعة (Collection Group)
    match /{path=**}/bookings/{bookingId} {
      allow read, write: if true;
    }
    
    match /{path=**}/parcels/{parcelId} {
      allow read, write: if true;
    }
  }
}