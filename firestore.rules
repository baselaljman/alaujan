rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // التوقيت الحالي لإعادة النشر: 2024-03-20T12:00:00Z
    
    /**
     * 1. القواعد العامة للمجموعات العادية
     */
    match /{document=**} {
      allow read, write: if true;
    }
    
    /**
     * 2. قواعد استعلامات المجموعات (Collection Group Rules)
     * ضرورية لعمل وظائف "تذاكري" و "تتبع الطرود" و "إحصائيات الإدارة".
     * يجب تعريفها بشكل منفصل لتعمل مع استعلامات collectionGroup.
     */
    
    match /{path=**}/bookings/{bookingId} {
      allow read, write: if true;
    }
    
    match /{path=**}/parcels/{parcelId} {
      allow read, write: if true;
    }
    
    match /{path=**}/notifications/{notificationId} {
      allow read, write: if true;
    }

    match /{path=**}/staff_permissions/{staffId} {
      allow read, write: if true;
    }

    match /{path=**}/drivers/{driverId} {
      allow read, write: if true;
    }
    
    match /{path=**}/mail/{mailId} {
      allow read, write: if true;
    }
  }
}