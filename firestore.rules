rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. القاعدة العامة: السماح بالوصول الكامل لجميع المستندات والمجموعات
    // تم استخدام {document=**} لتغطية كافة المجموعات والمجموعات الفرعية
    match /{document=**} {
      allow read, write: if true;
    }
    
    // 2. السماح الصريح لاستعلامات المجموعات (Collection Group Queries)
    // هذا الجزء حيوي جداً لعمل وظيفة "البحث عن التذاكر" و "إحصائيات الإدارة"
    // حيث يسمح بالاستعلام عن أي مجموعة تسمى 'bookings' أو 'parcels' في أي مكان في القاعدة
    
    match /{path=**}/bookings/{bookingId} {
      allow read, write: if true;
    }
    
    match /{path=**}/parcels/{parcelId} {
      allow read, write: if true;
    }
    
    match /{path=**}/notifications/{notificationId} {
      allow read, write: if true;
    }

    match /{path=**}/staff_permissions/{staffId} {
      allow read, write: if true;
    }

    match /{path=**}/drivers/{driverId} {
      allow read, write: if true;
    }
  }
}