rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * 1. القاعدة العامة (Recursive Match)
     * تسمح بالقراءة والكتابة لكافة المستندات لضمان عمل التطبيق بدون عوائق برمجية.
     */
    match /{document=**} {
      allow read, write: if true;
    }
    
    /**
     * 2. قواعد استعلامات المجموعات (Collection Group Rules)
     * ضرورية لعمليات البحث والإحصائيات التي تشمل كافة المستخدمين.
     * نستخدم {path=**} للسماح بالاستعلام عن المجموعات أياً كان مكانها.
     */
    
    match /{path=**}/bookings/{bookingId} {
      allow read, write: if true;
    }
    
    match /{path=**}/parcels/{parcelId} {
      allow read, write: if true;
    }
    
    match /{path=**}/busTrips/{tripId} {
      allow read, write: if true;
    }

    match /{path=**}/users/{userId} {
      allow read, write: if true;
    }

    match /{path=**}/locations/{locationId} {
      allow read, write: if true;
    }

    match /{path=**}/staff_permissions/{staffId} {
      allow read, write: if true;
    }

    /**
     * بصمة زمنية لضمان تحديث القواعد في سيرفرات Firebase فور التعديل.
     * التحديث الحالي يركز على حل مشكلة الصلاحيات للمدير العام والموظفين.
     * Timestamp: 2024-05-21T10:30:00Z
     */
  }
}