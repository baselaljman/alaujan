rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // تحديث القواعد لضمان الوصول الكامل للمجموعات واستعلامات المجموعات
    // التاريخ: 2024-03-21T11:00:00Z
    
    /**
     * 1. القاعدة العامة لكافة المستندات (Recursive Match)
     */
    match /{document=**} {
      allow read, write: if true;
    }
    
    /**
     * 2. قواعد استعلامات المجموعات (Collection Group Rules)
     * ضرورية لعمل وظائف "تذاكري" و "تتبع الطرود" و "إحصائيات الإدارة".
     * في إصدار rules_version = '2' يجب تعريفها بشكل منفصل لتغطية المسارات العميقة.
     */
    
    match /{path=**}/bookings/{id} {
      allow read, write: if true;
    }
    
    match /{path=**}/parcels/{id} {
      allow read, write: if true;
    }
    
    match /{path=**}/staff_permissions/{id} {
      allow read, write: if true;
    }

    match /{path=**}/notifications/{id} {
      allow read, write: if true;
    }

    match /{path=**}/drivers/{id} {
      allow read, write: if true;
    }
    
    match /{path=**}/mail/{id} {
      allow read, write: if true;
    }

    match /{path=**}/busTrips/{id} {
      allow read, write: if true;
    }

    match /{path=**}/buses/{id} {
      allow read, write: if true;
    }

    match /{path=**}/locations/{id} {
      allow read, write: if true;
    }

    match /{path=**}/users/{id} {
      allow read, write: if true;
    }
  }
}