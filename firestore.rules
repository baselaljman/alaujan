rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // القاعدة العامة: تسمح بالوصول للمستندات في المجموعات العادية
    match /{document=**} {
      allow read, write: if true;
    }
    
    // قواعد صريحة لاستعلامات المجموعات (Collection Group Queries)
    // ضرورية لتمكين البحث عن التذاكر والطرود والاشعارات عبر كافة مسارات المستخدمين
    
    match /{path=**}/bookings/{id} {
      allow read, write: if true;
    }
    
    match /{path=**}/parcels/{id} {
      allow read, write: if true;
    }
    
    match /{path=**}/notifications/{id} {
      allow read, write: if true;
    }
    
    match /{path=**}/staff_permissions/{id} {
      allow read, write: if true;
    }
    
    match /{path=**}/mail/{id} {
      allow read, write: if true;
    }
  }
}