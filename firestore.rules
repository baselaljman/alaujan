rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * 1. القاعدة العامة (Catch-all)
     * تسمح بالوصول الكامل لجميع المستندات في أي مسار تقليدي.
     */
    match /{document=**} {
      allow read, write: if true;
    }
    
    /**
     * 2. قواعد استعلامات المجموعات (Collection Group Rules)
     * ضرورية جداً لعمل وظائف "تذاكري" و "تتبع الطرود" و "إحصائيات الإدارة".
     * هذه القواعد تسمح للمتصفح بالبحث في أي مجموعة تحمل هذه الأسماء في أي مكان في الشجرة.
     */
    
    match /{path=**}/bookings/{bookingId} {
      allow read, write: if true;
    }
    
    match /{path=**}/parcels/{parcelId} {
      allow read, write: if true;
    }
    
    match /{path=**}/notifications/{notificationId} {
      allow read, write: if true;
    }

    match /{path=**}/staff_permissions/{staffId} {
      allow read, write: if true;
    }

    match /{path=**}/drivers/{driverId} {
      allow read, write: if true;
    }
    
    match /{path=**}/mail/{mailId} {
      allow read, write: if true;
    }
  }
}