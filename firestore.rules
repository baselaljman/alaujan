
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظيفة للتحقق مما إذا كان المستخدم مديراً معتمداً
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email in ["atlob.co@gmail.com", "alaujantravel@gmail.com"] || 
        request.auth.token.email.matches(".*@alawajan\\.com")
      );
    }

    // السماح للقراءة للموظفين والمديرين
    match /staff_permissions/{id} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ملفات المستخدمين: خصوصية تامة للمالك، وصول كامل للمدير
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      match /bookings/{bookingId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
      
      match /notifications/{notificationId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }

    // قواعد خاصة باستعلامات المجموعات (Collection Groups) - حصرياً للمدير والمالك
    match /{path=**}/bookings/{id} {
      allow read: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
    }
    
    match /{path=**}/parcels/{id} {
      allow read, write: if request.auth != null && (isAdmin() || resource.data.senderUserId == request.auth.uid);
    }

    // البيانات العامة للرحلات والمدن
    match /locations/{id} { allow read: if true; allow write: if isAdmin(); }
    match /buses/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /busRoutes/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /busTrips/{id} { allow read: if true; allow write: if isAdmin(); }
    match /drivers/{id} { allow read: if request.auth != null; allow write: if isAdmin(); }
    
    // خدمة البريد
    match /mail/{id} { allow create: if true; }

    /**
     * تحديث أمان نهائي: تفعيل استعلامات المجموعات (Manifest) للمديرين بشكل صريح.
     * DEPLOY_HASH: MANIFEST-FIX-V200
     */
  }
}
