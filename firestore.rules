rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * 1. القاعدة الشاملة لكافة المستندات (Recursive Match)
     * تسمح بالقراءة والكتابة لضمان عمل التطبيق بسلاسة تامة.
     */
    match /{document=**} {
      allow read, write: if true;
    }
    
    /**
     * 2. قواعد استعلامات المجموعات (Collection Group Rules)
     * ضرورية جداً لعمل وظائف "تذاكري" و "تتبع الطرود" و "إحصائيات الإدارة".
     * نستخدم {path=**} للسماح بالبحث في كافة المجموعات أياً كان مكانها في التسلسل الهرمي.
     */
    
    match /{path=**}/bookings/{id} {
      allow read, write: if true;
    }
    
    match /{path=**}/parcels/{id} {
      allow read, write: if true;
    }
    
    match /{path=**}/busTrips/{id} {
      allow read, write: if true;
    }

    match /{path=**}/staff_permissions/{id} {
      allow read, write: if true;
    }

    match /{path=**}/locations/{id} {
      allow read, write: if true;
    }

    match /{path=**}/buses/{id} {
      allow read, write: if true;
    }

    match /{path=**}/users/{id} {
      allow read, write: if true;
    }

    match /{path=**}/mail/{id} {
      allow read, write: if true;
    }

    /**
     * بصمة زمنية لضمان تحديث القواعد في سيرفرات Firebase فور التعديل.
     * تم التحديث الأخير لضمان حل مشكلة "Missing or insufficient permissions" بشكل نهائي.
     * Timestamp: 2024-05-20T14:30:00Z
     */
  }
}