rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // القاعدة الأساسية: السماح بالقراءة والكتابة لكافة المسارات المباشرة للمستخدمين المسجلين
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // تصاريح استعلامات المجموعات (Collection Group Queries) - ضرورية جداً للوحة الإدارة
    // هذه القواعد تسمح بالبحث في المجموعات بغض النظر عن موقعها في الهيكل الشجري
    
    match /{path=**}/bookings/{bookingId} {
      allow read, write: if request.auth != null;
    }
    
    match /{path=**}/parcels/{parcelId} {
      allow read, write: if request.auth != null;
    }
    
    match /{path=**}/busTrips/{tripId} {
      allow read, write: if request.auth != null;
    }

    match /{path=**}/users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /{path=**}/staff_permissions/{staffId} {
      allow read, write: if request.auth != null;
    }

    /**
     * بصمة التحديث لضمان إعادة النشر الفوري: DEPLOY-STABLE-GROUP-RULES-V10
     * تم تبسيط القواعد لضمان أعلى مستوى من التوافق مع استعلامات المجموعات.
     */
  }
}