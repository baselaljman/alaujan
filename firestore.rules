
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // السماح بالقراءة والكتابة لجميع المستندات والمجموعات بدون قيود
    // هذا يشمل الاستعلامات العادية والاستعلامات المجمعة (Collection Group)
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
