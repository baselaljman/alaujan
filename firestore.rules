
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظائف التحقق الأساسية
    function isAuthenticated() {
      return request.auth != null;
    }

    function getEmail() {
      return request.auth.token.email;
    }

    function hasEmail() {
      return isAuthenticated() && 'email' in request.auth.token && request.auth.token.email != null;
    }

    function isAdmin() {
      return hasEmail() && (
        getEmail().lower() in ["atlob.co@gmail.com", "alaujantravel@gmail.com"] || 
        getEmail().lower().matches(".*@alawajan\\.com")
      );
    }

    function isStaffMember() {
      return hasEmail() && exists(/databases/$(database)/documents/staff_permissions/$(getEmail().lower()));
    }

    // نظام الحجوزات - تأمين صارم مع السماح بفلترة المقاعد
    match /bookings/{bookingId} {
      allow create: if true;
      
      // السماح بالـ list فقط إذا كان الاستعلام "مفلتراً" أو للمديرين
      allow list: if isAdmin() || (
        // 1. السماح للجميع برؤية المقاعد المحجوزة في رحلة معينة (لاختيار المقاعد)
        (request.query.filters.busTripId != null) ||
        // 2. السماح للمسجلين برؤية تذاكرهم المرتبطة ببريدهم الموثق
        (hasEmail() && request.query.filters.userEmail == getEmail().lower()) ||
        // 3. السماح للضيوف برؤية تذاكرهم المرتبطة برقم جلستهم الحالية (UID)
        (isAuthenticated() && request.query.filters.userId == request.auth.uid)
      );
      
      allow get: if isAdmin() || 
                  (isAuthenticated() && (
                    resource.data.userId == request.auth.uid || 
                    (hasEmail() && resource.data.userEmail.lower() == getEmail().lower())
                  ));
      
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /busTrips/{id} { 
      allow read: if true;
      // السماح بتحديث عدد المقاعد المتاحة عند الحجز لكافة المستخدمين
      allow update: if isAuthenticated(); 
    }
    
    match /locations/{id} { allow read: if true; }
    match /buses/{id} { allow read: if true; }
    match /drivers/{id} { allow read: if true; }
    
    match /parcels/{id} {
      allow read: if isAdmin() || 
                   (hasEmail() && (resource.data.recipientEmail == getEmail() || resource.data.senderEmail == getEmail()));
      allow create: if isAuthenticated();
      allow update: if isAdmin();
    }
    
    match /staff_permissions/{email} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // القاعدة العامة للمديرين فقط
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
