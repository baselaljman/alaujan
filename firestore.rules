
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظيفة للتحقق مما إذا كان المستخدم مديراً معتمداً
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email in ["atlob.co@gmail.com", "alaujantravel@gmail.com"] || 
        request.auth.token.email.matches(".*@alawajan\\.com")
      );
    }

    // وظيفة للتحقق من ملكية البيانات
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // السماح للمسؤولين بالوصول الكامل والشامل لكافة المسارات (بما في ذلك Collection Groups)
    match /{path=**} {
      allow read, write: if isAdmin();
    }

    // قواعد للمستخدمين العاديين (لحماية خصوصيتهم)
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /bookings/{bookingId} {
        allow read, write: if isOwner(userId);
      }
      
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }
    }

    // قواعد الوصول للبيانات العامة للمستخدمين العاديين
    match /locations/{id} { allow read: if true; }
    match /busTrips/{id} { allow read: if true; }
    match /buses/{id} { allow read: if request.auth != null; }
    match /busRoutes/{id} { allow read: if request.auth != null; }
    match /drivers/{id} { allow read: if request.auth != null; }
    match /staff_permissions/{id} { allow read: if request.auth != null; }
    
    match /parcels/{id} {
      allow read, write: if request.auth != null && (resource == null || resource.data.senderUserId == request.auth.uid);
    }
    
    match /reviews/{id} {
      allow read: if true;
      allow write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }

    // خدمة البريد
    match /mail/{id} { allow create: if true; }
  }
}
