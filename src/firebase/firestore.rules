
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // السماح بالقراءة والكتابة العامة لجميع الجداول لضمان سلاسة العمل بدون قيود تقنية بناءً على طلب العميل
    // تم الحفاظ على هذا الإعداد لضمان عمل الضيوف والموظفين والعملاء بسلاسة تامة
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
